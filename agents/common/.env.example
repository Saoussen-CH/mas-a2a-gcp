# GCP Configuration for Brand Strategist Agent Deployment
# Copy this file to .env and fill in your values

# ============================================
# GCP Deployment Configuration
# ============================================
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_SERVICE_NAME=brand-strategist
GCP_SERVICE_ACCOUNT_NAME=brand-strategist-sa

# ============================================
# Runtime Configuration
# ============================================

# For Cloud Run / Production (uses Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ============================================
# A2A Server Configuration
# ============================================

# Local Development
HOST=0.0.0.0
PORT=8082
PUBLIC_HOST=localhost
PUBLIC_PORT=8082
PROTOCOL=http

# Cloud Run (set automatically by deployment script)
# PUBLIC_HOST=brand-strategist-PROJECT_NUMBER.us-central1.run.app
# PUBLIC_PORT=443
# PROTOCOL=https
