# ============================================
# GCP Configuration
# ============================================
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global   # Vertex AI model endpoint - "global" gives access to preview models
CLOUD_RUN_REGION=us-central1   # Cloud Run + Agent Runtime region - must be a real GCP region (not global)
GCS_IMAGES_BUCKET=your-project-id-campaign-images   # GCS bucket for generated images
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview   # Gemini model for native image generation (preview)

# ============================================
# Vertex AI / Gemini Configuration
# ============================================
GOOGLE_GENAI_USE_VERTEXAI=1
GEMINI_MODEL=gemini-3-flash-preview

# ============================================
# Observability (OpenTelemetry)
# ============================================
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=true
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
ADK_CAPTURE_MESSAGE_CONTENT_IN_SPANS=true

# ============================================
# Agent URLs (Auto-populated by deployment script)
# ============================================
COPYWRITER_AGENT_URL=
CRITIC_AGENT_URL=
DESIGNER_AGENT_URL=
PM_AGENT_URL=
STRATEGIST_AGENT_URL=

# ============================================
# Agent Runtime Configuration (Auto-populated)
# ============================================
AGENT_ENGINE_ID=
AGENT_ENGINE_RESOURCE_NAME=

# ============================================
# Optional: Notion Integration (Project Manager)
# ============================================
NOTION_TOKEN=
NOTION_PROJECT_DATABASE_ID=
NOTION_TASKS_DATABASE_ID=
