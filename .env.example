# ============================================
# GCP Configuration
# ============================================
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# ============================================
# Gemini API Configuration
# ============================================
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key

# ============================================
# Agent URLs (Auto-populated by deployment script)
# ============================================
# These will be automatically set after running deploy_complete_system.sh
# or deploy_all_specialists.py
STRATEGIST_AGENT_URL=
COPYWRITER_AGENT_URL=
DESIGNER_AGENT_URL=
CRITIC_AGENT_URL=
PM_AGENT_URL=

# ============================================
# Agent Engine Configuration (Auto-populated)
# ============================================
# These will be set after deploying the Creative Director orchestrator
# to Vertex AI Agent Engine
AGENT_ENGINE_RESOURCE_NAME=
AGENT_ENGINE_ID=

# ============================================
# Local Development Configuration
# ============================================
# For testing agents locally before deployment
HOST=0.0.0.0
PORT=8080
PUBLIC_HOST=localhost
PUBLIC_PORT=8080
PROTOCOL=http

# ============================================
# Optional: Notion Integration (Project Manager)
# ============================================
# Uncomment and set if you want to use Notion integration
# NOTION_API_KEY=your-notion-api-key
